<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Microphone Source -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Microphone Source"
            android:textSize="16sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerMicSource"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp" />

        <!-- Speaker Source -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Speaker Source"
            android:textSize="16sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerSpeakerSource"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp" />

        <!-- Output Format -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Output Format"
            android:textSize="16sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerFormat"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/spinner_background"
            android:padding="12dp" />

        <!-- Mic Volume -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Microphone Volume"
            android:textSize="16sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderMicVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="2.0"
                android:value="1.0"
                android:stepSize="0.05"
                app:thumbColor="@color/accent_blue"
                app:trackColorActive="@color/accent_blue"
                app:trackColorInactive="@color/divider" />

            <TextView
                android:id="@+id/tvMicVolumeValue"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Speaker Volume -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Speaker Volume"
            android:textSize="16sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderSpeakerVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="0.0"
                android:valueTo="2.0"
                android:value="0.5"
                android:stepSize="0.05"
                app:thumbColor="@color/accent_blue"
                app:trackColorActive="@color/accent_blue"
                app:trackColorInactive="@color/divider" />

            <TextView
                android:id="@+id/tvSpeakerVolumeValue"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Toggles -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchCaptureSpeaker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capture Speaker Audio"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-start on Boot"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAutoRecordCalls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-record incoming calls"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchAutoRecordOutgoing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-record outgoing calls"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <!-- Storage Path -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Storage Path"
            android:textSize="16sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etStoragePath"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="/storage/emulated/0/DCIM"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:background="@drawable/edittext_background"
                android:inputType="text"
                android:padding="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBrowseStorage"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Browse"
                android:textColor="@color/accent_blue"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Contact Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Filtering"
            android:textSize="18sp"
            android:textColor="@color/accent_blue"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="@drawable/card_background">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Included Contacts"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvIncludedContacts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected: All contacts (default)"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIncludedContacts"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                android:textColor="@color/accent_blue" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:background="@drawable/card_background"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Excluded Contacts"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvExcludedContacts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected: All contacts (default)"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExcludedContacts"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                android:textColor="@color/accent_blue" />
        </LinearLayout>

        <!-- Save / Cancel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Save"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="64dp" />

    </LinearLayout>

</ScrollView>
